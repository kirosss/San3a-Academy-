{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["guest", "member", "applicant", "learner", "contributor", "instructor", "interviewer", "reviewer", "coordinator", "supervisor", "admin"] },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Program": {
      "title": "Program",
      "description": "Educational programs and courses.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["hybrid", "virtual", "in-person"] },
        "status": { "type": "string", "enum": ["open", "closed", "upcoming"] },
        "featured": { "type": "boolean" },
        "image": { "type": "string" },
        "formFields": { "type": "array" }
      },
      "required": ["title", "description", "status"]
    },
    "Application": {
      "title": "Application",
      "description": "Program applications submitted by users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "programId": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "submitted", "under-review", "interview", "task", "accepted", "rejected", "waitlisted", "payment", "enrolled"] },
        "formData": { "type": "object" },
        "scores": { "type": "object" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "programId", "status"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "K-12 STEM lesson plans.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "declined", "scheduled"] },
        "content": { "type": "string" },
        "tags": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "authorId", "status"]
    },
    "News": {
      "title": "News",
      "description": "News and updates.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "image": { "type": "string" },
        "publishedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "published", "scheduled"] }
      },
      "required": ["title", "content", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/programs/{programId}": { "schema": "Program", "description": "Available programs" },
    "/applications/{applicationId}": { "schema": "Application", "description": "User applications" },
    "/lessons/{lessonId}": { "schema": "Lesson", "description": "STEM lessons" },
    "/news/{newsId}": { "schema": "News", "description": "News articles" }
  }
}
